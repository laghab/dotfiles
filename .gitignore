# ============================================
# WHITELIST APPROACH: Ignore everything by default,
# then explicitly un-ignore only tracked files
# ============================================

# Ignore everything at root level
/*
!/.gitignore

# === SHELL ===
!/.bashrc
!/.zshrc

# === GIT ===
!/.gitconfig

# === .CONFIG DIRECTORY ===
!/.config
/.config/*
!/.config/fish
.config/fish/*
!/.config/fish/config.fish
!/.config/fish/fish_variables
!/.config/fish/conf.d
.config/fish/conf.d/*
!/.config/fish/conf.d/fish_frozen_key_bindings.fish

!/.config/kitty
.config/kitty/*
!/.config/kitty/kitty.conf
!/.config/kitty/current-theme.conf

!/.config/fastfetch
