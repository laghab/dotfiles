# YADM REPO (critical - never track yadm tracking itself)
.local/share/yadm/

# Standard user data dirs (not configs)
Desktop/
Documents/
Downloads/
Music/
Pictures/
Videos/
Public/
Templates/
Projects/

# Caches & temp
.cache/
.cache/**
**/cache/**
**/*.cache
.npm/
.cargo/
.viminfo
.bash_history
.zsh_history
.wget-hsts
**/__pycache__/
*.pyc
.local/share/Trash/
.local/share/baloo/
.local/share/kactivitymanagerd/

# Sessions, locks & state
.session/
session/
**/session/**
**/*.lock
**/*.pid
.local/state/

# Browser profiles (massive, auto-generated)
.config/BraveSoftware/
.mozilla/
.chromium/
google-chrome/

# Gaming (massive)
Steam/
.steam/
.config/Proton/
.proton/

# Discord (huge binaries: 180MB app, 100MB modules)
.config/discord/

# Flatpak
.var/
snap/

# Secrets (handle separately)
.ssh/
.gnupg/
**/secrets/
**/authinfo*
**/netrc

# Large app data
.config/libreoffice/
.config/obsidian/**
.config/obsidian/.obsidian/workspace
.aws/
.docker/

# Audio state (changes constantly)
.config/pulse/
.config/pipewire/
.config/wireplumber/
.alsaequal/

# Desktop trash/thumbnails
.trash/
.thumbnails/
**.Trash-*/

# Discord / Vesktop / Vencord caches (not config)
.config/vesktop/sessionData/
.config/vesktop/Crashpad/
.config/Vencord/dist/

# Shell history (changes constantly)
.local/share/fish/fish_history
.local/share/fish/fish_history_*

# Recently-used files (changes constantly)
.local/share/recently-used.xbel

# Certificate databases (auto-generated)
.pki/



# Node / JS
node_modules/
**/node_modules/
**/package-lock.json
yarn.lock
pnpm-lock.yaml

# Build artifacts
**/*.o
**/*.so
**/*.a
**/*.exe
**/*.dll
**/*.class
**/*.jar

# Editor backups
**/*~
**/*.swp
**/*.swo
**/*.un~
**/*.bak.*
**/*.backup*
