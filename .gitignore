# ============================================
# SAFETY IGNORES (backup layer for untracked files)
# ============================================

# YADM repo itself
.local/share/yadm/

# Standard user dirs
Desktop/
Documents/
Downloads/
Music/
Pictures/
Videos/
Public/
Templates/
Projects/

# Caches & temp
.cache/
.cache/**
**/cache/**
**/*.cache
.npm/
.cargo/
.viminfo
.bash_history
.zsh_history
.wget-hsts
**/__pycache__/
*.pyc
.local/share/Trash/
.local/share/baloo/
.local/share/kactivitymanagerd/

# Sessions, locks & state
.session/
session/
**/session/**
**/*.lock
**/*.pid
.local/state/

# Browser profiles
.config/BraveSoftware/
.mozilla/
.chromium/
google-chrome/

# Gaming
Steam/
.steam/
.config/Proton/
.proton/
Games/
Faugus/
.local/share/umu/
.wine/

# Discord (binaries)
.config/discord/

# Flatpak/snap
.var/
snap/

# Secrets
.ssh/
.gnupg/
**/secrets/
**/authinfo*
**/netrc

# Large app data
.config/libreoffice/
.config/obsidian/**
.config/obsidian/.obsidian/workspace
.aws/
.docker/

# Rotating state
.config/pulse/
.config/pipewire/
.config/wireplumber/
.alsaequal/
.local/share/fish/fish_history
.local/share/fish/fish_history_*
.local/share/recently-used.xbel
.local/share/klipper/

# Opencode
.local/share/opencode/
.opencode/

# Certificates
.pki/

# Android
.android/

# GPU state
.nv/

# Launcher runtime
.config/faugus-launcher/icons/
.config/faugus-launcher/games-backup/

# Python
.local/lib/

# Anki
.local/share/Anki2/

# qBittorrent state
.local/share/qBittorrent/

# Volatile KDE state
.config/kactivitymanagerd-statsrc
.config/okularpartrc
.config/plasmanotifyrc
.config/trashrc

# Tool binaries (not configs)
.local/bin/

# KDE runtime
.local/share/krunnerstaterc
.local/share/libkunitconversion/
.local/share/kwrite/anonymous.katesession
.local/share/plasmalogin/
.local/share/user-places.xbel
.local/share/user-places.xbel.bak
.local/share/user-places.xbel.tbcache

# KDE secrets/wallets
.config/kdeconnect/privateKey.pem
.config/kdeconnect/certificate.pem
.config/libaccounts-glib/accounts.db
.config/libaccounts-glib/accounts.db-shm
.config/libaccounts-glib/accounts.db-wal
.local/share/keyrings/
.local/share/kwalletd/

# Faugus runtime
.local/share/faugus-launcher/running_games.json
.local/share/faugus-launcher/version.txt
.local/share/faugus-launcher/umu-run

# CachyOS logs
.config/cachyos/cachyos-hello/cachyos-hello.log

# gh per-machine state
.config/gh/hosts.yml

# GTK assets (SVGs)
.config/gtk-3.0/assets/
.config/gtk-4.0/assets/

# Cursor themes
.icons/

# VLC state
.local/share/vlc/ml.xspf

# Opentui
.local/share/opentui/

# Go cache
go/
.local/share/go/

# Container storage
.local/share/containers/

# Kitty backups
.config/kitty-bak/
.config/kitty/kitty.conf.bak

# Node
node_modules/
**/node_modules/
**/package-lock.json
yarn.lock
pnpm-lock.yaml

# Stremio
.stremio-server/
.local/share/Smart Code/

# Build artifacts
**/*.o
**/*.so
**/*.a
**/*.exe
**/*.dll
**/*.class
**/*.jar

# Editor backups
**/*~
**/*.swp
**/*.swo
**/*.un~
**/*.bak.*
**/*.backup*

# Zed runtime data
.local/share/zed/db/
.local/share/zed/logs/
.local/share/zed/prompts/
.local/share/zed/threads/

# Stale package lists moved to .config/
pkglist.txt
aur-pkglist.txt

# Micro editor bundled files
.config/micro/buffers/
.config/micro/syntax/
.config/micro/colorschemes/

# PulseAudio (per-machine, regenerated)
.pulse-cookie

# Steam (per-machine)
.steampath
.steampid

# Wallpapers (binary images)
.local/share/wallpapers/

# Aurorae window decorations (reinstallable)
.local/share/aurorae/

# Plasma widgets (reinstallable)
.local/share/plasma/

# Autopsy (removed app)
.autopsy/

# Color schemes (reinstallable)
.local/share/color-schemes/

# Java font info
.java/

# Desktop entries (auto-generated)
.local/share/applications/
