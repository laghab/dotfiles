# === yt-dlp config for ytermusic ===

# Geo-bypass for region-locked content (set to US as requested)
--geo-bypass
--geo-bypass-country US

# Audio extraction for music
--extract-audio
--audio-format mp3
--audio-quality 0
--no-playlist
--no-check-certificates

# Authentication via cookies from your YouTube Music session
--cookies /home/laghab/.config/yt-dlp/cookies.txt

# Browser-like headers to avoid blocks
--add-header "Accept-Language: en-US,en;q=0.9"
--add-header "Origin: https://music.youtube.com"
--add-header "Referer: https://music.youtube.com/"
--user-agent "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/141.0.0.0 Safari/537.36"
