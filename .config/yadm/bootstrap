#!/bin/bash
# yadm bootstrap — runs automatically after `yadm clone` on a new machine
set -e

echo "=== Restoring packages ==="
if command -v pacman &>/dev/null; then
  if [ -f ~/pkglist.txt ]; then
    sudo pacman -S --needed --noconfirm - < ~/pkglist.txt 2>/dev/null || echo "Some packages may have been skipped"
  fi
  if [ -f ~/aur-pkglist.txt ]; then
    if command -v paru &>/dev/null; then
      paru -S --needed --noconfirm - < ~/aur-pkglist.txt 2>/dev/null || echo "Some AUR packages may have been skipped"
    elif command -v yay &>/dev/null; then
      yay -S --needed --noconfirm - < ~/aur-pkglist.txt 2>/dev/null || echo "Some AUR packages may have been skipped"
    else
      echo "No AUR helper found. Install paru or yay, then run:"
      echo "  paru -S --needed - < ~/aur-pkglist.txt"
    fi
  fi
fi

echo ""
echo "=== Deploying Polonium patches ==="
if [ -d ~/.config/polonium ] && [ -d /usr/share/kwin/scripts/polonium/ ]; then
  sudo cp -a ~/.config/polonium/. /usr/share/kwin/scripts/polonium/
  echo "Polonium patches applied to /usr/share/kwin/scripts/polonium/"
elif [ -d ~/.config/polonium ]; then
  echo "WARNING: ~/.config/polonium/ exists but /usr/share/kwin/scripts/polonium/ does not."
  echo "Install kwin-polonium from AUR first, then re-run this bootstrap."
fi

echo ""
echo "=== Setup complete ==="
echo "All config files have been restored to ~/.config/"
echo "You may need to log out and back in for all settings to apply."
