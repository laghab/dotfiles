{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/master/doc/json_schema.json",

  "logo": {
    "type": "file",
    "source": "/home/laghab/.config/fastfetch/purin-logo.txt",
    "padding": {
      "top": 0,
      "left": 1,
      "right": 3
    }
  },

  "display": {
    "pipe": false,
    "separator": "  ",
    "color": {
      "keys": "#FF85C8",
      "title": "#FFA0D0",
      "output": "#D8DEE9",
      "separator": "#525A6B"
    },
    "key": {
      "width": 15
    }
  },

  "modules": [
    { "type": "custom", "format": "" },
    { "type": "custom", "format": "" },
    {
      "type": "title",
      "format": "{#1}╭───────────── {#}{user-name-colored}"
    },
    {
      "type": "custom",
      "format": "{#1}│ {#}System Information"
    },
    {
      "type": "os",
      "key": "{#separator}│  {#keys}OS"
    },
    {
      "type": "kernel",
      "key": "{#separator}│  {#keys}Kernel",
      "format": "{release} {arch}"
    },
    {
      "type": "uptime",
      "key": "{#separator}│  {#keys}Uptime"
    },
    {
      "type": "packages",
      "key": "{#separator}│  {#keys}Packages",
      "format": "{all}"
    },
    {
      "type": "custom",
      "format": "{#1}│"
    },
    {
      "type": "custom",
      "format": "{#1}│ {#}Hardware Information"
    },
    {
      "type": "cpu",
      "key": "{#separator}│  {#keys}CPU",
      "format": "{name} ({cores-physical}C / {cores-logical}T)"
    },
    {
      "type": "gpu",
      "key": "{#separator}│  {#keys}GPU",
      "format": "{name} [{type}]"
    },
    {
      "type": "memory",
      "key": "{#separator}│  {#keys}Memory",
      "format": "{used} / {total}"
    },
    {
      "type": "disk",
      "key": "{#separator}│  {#keys}Disk (/)",
      "folders": "/",
      "format": "{size-used} / {size-total}"
    },
    {
      "type": "custom",
      "format": "{#1}│"
    },
    {
      "type": "custom",
      "format": "{#1}│ {#}Software"
    },
    {
      "type": "shell",
      "key": "{#separator}│  {#keys}Shell",
      "format": "{pretty-name} {version}"
    },
    {
      "type": "terminal",
      "key": "{#separator}│  {#keys}Terminal",
      "format": "{pretty-name} {version}"
    },
    {
      "type": "terminalfont",
      "key": "{#separator}│  {#keys}Font"
    },
    {
      "type": "custom",
      "format": "{#1}│"
    },
    {
      "type": "colors",
      "key": "{#separator}│",
      "symbol": "circle"
    },
    { "type": "custom", "format": "" },
    { "type": "custom", "format": "" },
    {
      "type": "custom",
      "format": "{#1}╰───────────────────────────────╯"
    }
  ]
}
