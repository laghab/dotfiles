{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "read": { "*": "allow", "~/secrets/**": "deny" },
    "edit": { "*": "allow", "~/secrets/**": "deny" },
    "glob": { "*": "allow", "~/secrets/**": "deny" },
    "grep": { "*": "allow", "~/secrets/**": "deny" },
    "list": { "*": "allow", "~/secrets/**": "deny" },
    "external_directory": { "*": "allow", "~/secrets/**": "deny" }
  }
}