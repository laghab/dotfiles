#!/usr/bin/env python3
import os
import sys
import signal
import select
import time
import logging
import subprocess

import evdev
from evdev import ecodes, InputDevice, list_devices, UInput

KEY_LEFTALT = ecodes.KEY_LEFTALT
REL_WHEEL = ecodes.REL_WHEEL
REL_WHEEL_HI_RES = ecodes.REL_WHEEL_HI_RES
REL_HWHEEL = ecodes.REL_HWHEEL
REL_HWHEEL_HI_RES = ecodes.REL_HWHEEL_HI_RES
REL_X = ecodes.REL_X
REL_Y = ecodes.REL_Y
EV_KEY = ecodes.EV_KEY
EV_REL = ecodes.EV_REL
EV_SYN = ecodes.EV_SYN
SYN_REPORT = ecodes.SYN_REPORT

SCROLL_CODES = {REL_WHEEL, REL_WHEEL_HI_RES, REL_HWHEEL, REL_HWHEEL_HI_RES}

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s %(message)s",
    datefmt="%H:%M:%S",
)

STEP = "5%"

grabbed_mice = []
uinput_devices = []


def cleanup():
    for md in grabbed_mice:
        try:
            md.ungrab()
        except Exception:
            pass
    for ui in uinput_devices:
        try:
            ui.close()
        except Exception:
            pass


def volume(direction):
    suffix = f"{STEP}+" if direction == "up" else f"{STEP}-"
    subprocess.run(
        ["wpctl", "set-volume", "@DEFAULT_AUDIO_SINK@", suffix],
        capture_output=True,
    )


def build_uinput_caps(dev):
    caps = dev.capabilities(absinfo=False)
    result = {}
    for etype, codes in caps.items():
        if etype == EV_SYN:
            continue
        clean = []
        for c in codes:
            if isinstance(c, tuple):
                clean.append(c[0])
            else:
                clean.append(c)
        result[etype] = clean
    return result


def find_devices():
    kbs = []
    mice = []
    for path in list_devices():
        try:
            dev = InputDevice(path)
        except (OSError, PermissionError):
            continue
        caps = dev.capabilities(absinfo=False)
        keys = caps.get(EV_KEY, [])
        rel = caps.get(EV_REL, [])
        is_kb = ecodes.KEY_A in keys
        is_mouse = rel and REL_WHEEL in rel
        if is_kb:
            kbs.append(dev)
        elif is_mouse:
            mice.append(dev)
        else:
            dev.close()
    return kbs, mice


def main():
    global grabbed_mice, uinput_devices

    kbs, mice = find_devices()
    if not kbs or not mice:
        logging.error("no keyboards or mice found")
        sys.exit(1)

    logging.info("kb=%d ms=%d", len(kbs), len(mice))
    for d in kbs:
        logging.info("  KB: %s  %s", d.path, d.name)
    for d in mice:
        logging.info("  MS: %s  %s", d.path, d.name)

    # Create uinput passthrough devices BEFORE grabbing
    mouse_to_ui = {}
    for md in mice:
        caps = build_uinput_caps(md)
        try:
            ui = UInput(caps, name=f"ws-vol-{md.name}", version=1)
            uinput_devices.append(ui)
            mouse_to_ui[md.path] = ui
        except Exception as e:
            logging.error("failed to create uinput for %s: %s", md.path, e)
            cleanup()
            sys.exit(1)

    # Now grab all mice exclusively
    for md in mice:
        try:
            md.grab()
            grabbed_mice.append(md)
        except Exception as e:
            logging.error("failed to grab %s: %s", md.path, e)

    if not grabbed_mice:
        logging.error("no mice could be grabbed")
        cleanup()
        sys.exit(1)

    logging.info("grabbed %d mice, created %d uinput passthrough devices",
                 len(grabbed_mice), len(uinput_devices))

    alt_pressed = {dev.path: False for dev in kbs}
    fd_to_dev = {}
    for dev in kbs + grabbed_mice:
        fd_to_dev[dev.fd] = dev

    while True:
        try:
            r, w, x = select.select(list(fd_to_dev.keys()), [], [])
            for fd in r:
                dev = fd_to_dev[fd]
                for event in dev.read():
                    if dev.path in alt_pressed:
                        # Keyboard event — track Alt
                        if event.type == EV_KEY and event.code == KEY_LEFTALT:
                            alt_pressed[dev.path] = bool(event.value)
                            continue
                        continue

                    # Mouse event — forward everything except scroll when Alt held
                    is_scroll = event.type == EV_REL and event.code in SCROLL_CODES
                    alt_held = any(alt_pressed.values())

                    if is_scroll and alt_held:
                        if event.code == REL_WHEEL:
                            if event.value == 1:
                                volume("up")
                                logging.info("volume up")
                            elif event.value == -1:
                                volume("down")
                                logging.info("volume down")
                        continue

                    ui = mouse_to_ui.get(dev.path)
                    if ui:
                        ui.write(event.type, event.code, event.value)

        except (select.error, OSError) as e:
            logging.error("device error: %s, re-scanning...", e)
            break

    cleanup()


if __name__ == "__main__":
    signal.signal(signal.SIGINT, lambda s, f: (cleanup(), sys.exit(0)))
    signal.signal(signal.SIGTERM, lambda s, f: (cleanup(), sys.exit(0)))
    main()
